<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.devslane.meetingrecorder</string>
    <key>CFBundleName</key>
    <string>mac-recorder</string>
    <!-- Run UI-less: no Dock icon, never becomes foreground. Without this the
         headless helper tries to activate as a foreground app (no window) and
         macOS bounces the parent (Gotcha) Dock icon while recording. -->
    <key>LSUIElement</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>Records your microphone so your side of the meeting is transcribed.</string>
</dict>
</plist>
