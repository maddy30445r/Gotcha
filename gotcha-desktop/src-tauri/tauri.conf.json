{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gotcha",
  "version": "0.1.0",
  "identifier": "com.gotcha.desktop",
  "build": {
    "frontendDist": "../../webapp/static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gotcha",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["gotcha"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
