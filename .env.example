# Copy this file to .env and fill in your real keys.
#   cp .env.example .env

# Transcription (Sarvam) — https://dashboard.sarvam.ai
SARVAM_API_KEY=your_key_here

# Interpretation (LLM). Default provider is Groq (free testing tier).
GROQ_API_KEY=your_key_here          # free testing tier — https://console.groq.com/keys
ANTHROPIC_API_KEY=your_key_here     # no-train tier for REAL meetings (privacy rule)
GEMINI_API_KEY=your_key_here        # optional alternate provider

# Switch provider/model without code changes:
#   groq (default, free)  |  anthropic (no-train)  |  gemini
# GOTCHA_LLM_PROVIDER=anthropic
# GOTCHA_LLM_MODEL=claude-haiku-4-5
