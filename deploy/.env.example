# Copy to deploy/.env on the host and fill in. NEVER commit the filled file.
# Managed keys: the backend pays Sarvam + the LLM; clients never see these.

# Sarvam STT (two-track transcription). Required.
SARVAM_API_KEY=

# LLM interpret step. Pick ONE provider via GOTCHA_LLM_PROVIDER and set its key.
#
#   groq       — free/fast, project default. ⚠️ testing tier → NON-confidential /
#                test meetings only (may train on inputs).
#   anthropic  — no-train tier → REQUIRED for real/confidential meetings. ~1–2¢/meeting.
#
# Default (testing): Groq.
GROQ_API_KEY=
GOTCHA_LLM_PROVIDER=groq
GOTCHA_LLM_MODEL=llama-3.3-70b-versatile

# For real meetings, set the key below and flip the two vars above to:
#   GOTCHA_LLM_PROVIDER=anthropic
#   GOTCHA_LLM_MODEL=claude-haiku-4-5
# (or pin only specific users to anthropic via the "provider" field in users.json,
#  leaving everyone else on the Groq default). NOTE: the code reads ANTHROPIC_API_KEY
#  — name it exactly this, not CLAUDE_KEY.
ANTHROPIC_API_KEY=

# Per-user usage cap in minutes (billed = system + mic seconds). Over-cap uploads
# PARK (audio kept) instead of failing. Default 120.
GOTCHA_DEFAULT_CAP_MIN=120

# Global wallet stop: hard ceiling on PAID (Sarvam) minutes processed across ALL
# users per calendar day — the budget backstop for an open launch. Over-ceiling
# meetings PARK (audio kept, no paid work) and can be processed once it resets.
# 0 = unlimited (off). Set this before a public launch, e.g. 600 (~$8/day max).
GOTCHA_GLOBAL_DAILY_CAP_MIN=0

# Max upload size per request in MB (keep <= Caddy's request_body max_size). Default 300.
GOTCHA_MAX_UPLOAD_MB=300

# ── Self-serve auth (Milestone 2) ───────────────────────────────────────────
# Public HTTPS base URL of this backend (for email links + OAuth redirects).
GOTCHA_PUBLIC_URL=https://your-domain
# Random secret that signs session cookies (keep stable so logins survive restarts):
#   generate with:  python3 -c "import secrets; print(secrets.token_hex(32))"
GOTCHA_SESSION_SECRET=
# Free usage cap (minutes) for a brand-new self-serve signup. Default 30.
GOTCHA_FREE_CAP_MIN=30
# Transactional email (magic-link sign-in). No key → links print to the container
# log instead of sending (dev). Resend: https://resend.com
RESEND_API_KEY=
RESEND_FROM=Gotcha <onboarding@resend.dev>
# Google sign-in (OAuth). Create a client at console.cloud.google.com; authorized
# redirect URI = ${GOTCHA_PUBLIC_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
