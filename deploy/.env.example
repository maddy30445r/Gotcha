# Copy to deploy/.env on the host and fill in. NEVER commit the filled file.
# Managed keys: the backend pays Sarvam + the LLM; clients never see these.

# Sarvam STT (two-track transcription). Required.
SARVAM_API_KEY=

# Gemini (interpret step). Required until the paid/no-train LLM swap lands.
# ⚠️  Free tier may TRAIN on inputs → alpha = non-confidential / test meetings only.
GEMINI_API_KEY=

# Per-user usage cap in minutes (billed = system + mic seconds). Over-cap uploads
# PARK (audio kept) instead of failing. Default 120.
GOTCHA_DEFAULT_CAP_MIN=120

# Max upload size per request in MB (keep <= Caddy's request_body max_size). Default 300.
GOTCHA_MAX_UPLOAD_MB=300
