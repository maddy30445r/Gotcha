# Replace the hostname with your DuckDNS (or any) domain pointed at this VM's
# public IP. Caddy auto-provisions + renews a Let's Encrypt cert on first request,
# so this two-line block is the whole TLS setup.
#
# Audio uploads are large two-track WAVs (cap GOTCHA_MAX_UPLOAD_MB, default 300MB);
# raise Caddy's request body limit to match so big meetings aren't rejected at the
# proxy before reaching the app's own size check.
gotcha-app.duckdns.org {
	request_body {
		max_size 350MB
	}
	# Baseline security headers (HSTS forces HTTPS for a year; nosniff + DENY block
	# MIME-sniffing and clickjacking; no-referrer keeps URLs out of outbound Referer).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
	reverse_proxy app:8000
}
